{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "carousel",
  "version": "0.1.0",
  "description": "A responsive, accessible carousel — a scroll-snap viewport of slides with prev/next controls and indicator dots (WAI-ARIA Carousel pattern). Adapts to its container by default.",
  "docs": "https://primitiv-ui.dev/docs/components/carousel",
  "root": {
    "element": "section",
    "class": "primitiv-carousel",
    "component": "Root"
  },
  "dataAttributes": [
    { "name": "data-orientation", "value": "horizontal", "when": "horizontal", "source": "auto" },
    { "name": "data-orientation", "value": "vertical", "when": "vertical", "source": "auto" },
    { "name": "data-transition", "value": "slide", "when": "slide", "source": "auto" },
    { "name": "data-transition", "value": "fade", "when": "fade", "source": "auto" },
    { "name": "data-transition", "value": "none", "when": "none", "source": "auto" }
  ],
  "modifiers": [
    {
      "name": "peek",
      "default": "none",
      "description": "Reveal a sliver of the adjacent slides on either side of the active one. Works in both orientations (inline edges when horizontal, block edges when vertical).",
      "options": [
        { "name": "none", "class": "primitiv-carousel--peek-none", "description": "No peek — the active slide fills the viewport (the default)." },
        { "name": "sm", "class": "primitiv-carousel--peek-sm", "description": "A small peek." },
        { "name": "md", "class": "primitiv-carousel--peek-md", "description": "A medium peek." },
        { "name": "lg", "class": "primitiv-carousel--peek-lg", "description": "A large peek." }
      ]
    },
    {
      "name": "padding",
      "default": "none",
      "description": "Inset the whole carousel from its container with an outer gutter (breathing room framing the viewport). Distinct from `peek`: padding is the outer gutter and never reveals neighbouring slides, whereas peek is the inner reveal — they stack, so with both set the edge inset is padding + peek while the neighbour reveal stays exactly peek. Frames every edge in both orientations (so the side opposite the controls is padded too); the internal viewport-to-controls spacing stays the block gap's job.",
      "options": [
        { "name": "none", "class": "primitiv-carousel--padding-none", "description": "No viewport padding — the carousel fills its container edge to edge (the default)." },
        { "name": "sm", "class": "primitiv-carousel--padding-sm", "description": "A small gutter." },
        { "name": "md", "class": "primitiv-carousel--padding-md", "description": "A medium gutter." },
        { "name": "lg", "class": "primitiv-carousel--padding-lg", "description": "A large gutter." }
      ]
    },
    {
      "name": "placement",
      "default": "row",
      "description": "Where the prev/next controls and indicator dots sit relative to the viewport. The default keeps them in a flow row below (compose them in a `<CarouselControls>` wrapper); `overlay` insets the controls on the slide for edge-to-edge imagery.",
      "options": [
        { "name": "row", "class": "primitiv-carousel--placement-row", "description": "Controls flow in a row below the viewport (the default)." },
        { "name": "overlay", "class": "primitiv-carousel--placement-overlay", "description": "Controls sit on the imagery — prev/next flanking the slide edges on a translucent scrim, dots in a pill overlaid at the bottom." }
      ]
    }
  ],
  "styleProps": [
    { "prop": "slidesPerPage", "cssVar": "--primitiv-carousel-slides-per-page" }
  ],
  "subcomponents": [
    {
      "name": "viewport",
      "component": "Viewport",
      "element": "div",
      "class": "primitiv-carousel__viewport"
    },
    {
      "name": "controls",
      "element": "div",
      "class": "primitiv-carousel__controls"
    },
    {
      "name": "slide",
      "component": "Slide",
      "element": "div",
      "class": "primitiv-carousel__slide",
      "modifiers": [
        {
          "name": "radius",
          "default": "md",
          "description": "Corner rounding of the slide.",
          "options": [
            { "name": "md", "class": "primitiv-carousel__slide--radius-md", "description": "Medium rounded corners (the default)." },
            { "name": "none", "class": "primitiv-carousel__slide--radius-none", "description": "Sharp, un-rounded corners." }
          ]
        }
      ],
      "dataAttributes": [
        { "name": "data-state", "value": "active", "when": "active", "source": "auto" },
        { "name": "data-state", "value": "inactive", "when": "inactive", "source": "auto" }
      ]
    },
    {
      "name": "previous-trigger",
      "component": "PreviousTrigger",
      "element": "button",
      "class": "primitiv-carousel__prev"
    },
    {
      "name": "next-trigger",
      "component": "NextTrigger",
      "element": "button",
      "class": "primitiv-carousel__next"
    },
    {
      "name": "indicator-group",
      "component": "IndicatorGroup",
      "element": "div",
      "class": "primitiv-carousel__indicator-group"
    },
    {
      "name": "indicator",
      "component": "Indicator",
      "element": "button",
      "class": "primitiv-carousel__indicator",
      "dataAttributes": [
        { "name": "data-state", "value": "active", "when": "active", "source": "auto" },
        { "name": "data-state", "value": "inactive", "when": "inactive", "source": "auto" }
      ]
    },
    {
      "name": "indicators",
      "component": "Indicators",
      "element": "div",
      "class": "primitiv-carousel__indicator-group"
    }
  ],
  "customProperties": [
    { "name": "--primitiv-carousel-gap", "defaultsTo": "var(--primitiv-space-space-16)" },
    { "name": "--primitiv-carousel-peek", "defaultsTo": "var(--primitiv-space-space-0)" },
    { "name": "--primitiv-carousel-viewport-padding", "defaultsTo": "var(--primitiv-space-space-0)" },
    { "name": "--primitiv-carousel-slides-per-page", "defaultsTo": "1" },
    { "name": "--primitiv-carousel-slide-aspect-ratio", "defaultsTo": "16 / 9" },
    { "name": "--primitiv-carousel-vertical-aspect-ratio", "defaultsTo": "16 / 9" },
    { "name": "--primitiv-carousel-slide-radius", "defaultsTo": "var(--primitiv-radii-12)" },
    { "name": "--primitiv-carousel-block-gap", "defaultsTo": "var(--primitiv-space-space-16)" },
    { "name": "--primitiv-carousel-controls-gap", "defaultsTo": "var(--primitiv-space-space-16)" },
    { "name": "--primitiv-carousel-control-size", "defaultsTo": "var(--primitiv-space-space-32)" },
    { "name": "--primitiv-carousel-control-radius", "defaultsTo": "50%" },
    { "name": "--primitiv-carousel-control-bg", "defaultsTo": "var(--primitiv-action-secondary-default)" },
    { "name": "--primitiv-carousel-control-bg-hover", "defaultsTo": "var(--primitiv-action-secondary-hover)" },
    { "name": "--primitiv-carousel-control-bg-active", "defaultsTo": "var(--primitiv-action-secondary-active)" },
    { "name": "--primitiv-carousel-control-fg", "defaultsTo": "var(--primitiv-action-secondary-foreground-default)" },
    { "name": "--primitiv-carousel-control-icon-size", "defaultsTo": "var(--primitiv-space-space-16)" },
    { "name": "--primitiv-carousel-indicator-gap", "defaultsTo": "var(--primitiv-space-space-0)" },
    { "name": "--primitiv-carousel-indicator-hit-area", "defaultsTo": "var(--primitiv-space-space-24)" },
    { "name": "--primitiv-carousel-indicator-size", "defaultsTo": "var(--primitiv-space-space-8)" },
    { "name": "--primitiv-carousel-indicator-color", "defaultsTo": "var(--primitiv-border-strong)" },
    { "name": "--primitiv-carousel-indicator-color-active", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-carousel-overlay-control-inset", "defaultsTo": "var(--primitiv-space-space-8)" },
    { "name": "--primitiv-carousel-overlay-control-bg", "defaultsTo": "var(--primitiv-color-neutral-alpha-500)" },
    { "name": "--primitiv-carousel-overlay-control-bg-hover", "defaultsTo": "var(--primitiv-color-neutral-alpha-600)" },
    { "name": "--primitiv-carousel-overlay-control-bg-active", "defaultsTo": "var(--primitiv-color-neutral-alpha-700)" },
    { "name": "--primitiv-carousel-overlay-control-fg", "defaultsTo": "var(--primitiv-content-inverse)" },
    { "name": "--primitiv-carousel-overlay-indicator-inset", "defaultsTo": "var(--primitiv-space-space-8)" },
    { "name": "--primitiv-carousel-overlay-indicator-color", "defaultsTo": "var(--primitiv-color-neutral-alpha-inverse-500)" },
    { "name": "--primitiv-carousel-overlay-indicator-color-active", "defaultsTo": "var(--primitiv-content-inverse)" },
    { "name": "--primitiv-carousel-overlay-pill-bg", "defaultsTo": "var(--primitiv-color-neutral-alpha-500)" },
    { "name": "--primitiv-carousel-overlay-pill-padding-inline", "defaultsTo": "var(--primitiv-space-space-12)" },
    { "name": "--primitiv-carousel-overlay-pill-padding-block", "defaultsTo": "var(--primitiv-space-space-4)" },
    { "name": "--primitiv-carousel-fade-duration", "defaultsTo": "var(--primitiv-motion-duration-overlay)" },
    { "name": "--primitiv-carousel-fade-easing", "defaultsTo": "var(--primitiv-motion-easing-default)" }
  ]
}
