{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "segmented-control",
  "version": "0.1.0",
  "description": "A single-select segmented control — a linear strip of segments where exactly one is selected. The selected segment is brand-filled; the rest are secondary.",
  "docs": "https://primitiv-ui.dev/docs/components/segmented-control",
  "root": {
    "element": "div",
    "class": "primitiv-segmented-control",
    "component": "Root",
    "dataAttributes": [
      { "name": "data-orientation", "value": "horizontal", "when": "horizontal", "source": "auto" },
      { "name": "data-orientation", "value": "vertical", "when": "vertical", "source": "auto" },
      { "name": "data-disabled", "value": "", "when": "the whole control is disabled", "source": "auto" }
    ]
  },
  "modifiers": [
    {
      "name": "size",
      "default": "md",
      "description": "Control size for the whole control; `data-density` scales each size further.",
      "options": [
        { "name": "xs", "class": "primitiv-segmented-control--xs", "description": "Extra small." },
        { "name": "sm", "class": "primitiv-segmented-control--sm", "description": "Small." },
        { "name": "md", "class": "primitiv-segmented-control--md", "description": "Medium (the default)." },
        { "name": "lg", "class": "primitiv-segmented-control--lg", "description": "Large." },
        { "name": "xl", "class": "primitiv-segmented-control--xl", "description": "Extra large." }
      ]
    },
    {
      "name": "justify",
      "default": "content",
      "description": "Whether segments size to their content or share the track width equally.",
      "options": [
        { "name": "content", "class": "", "description": "Segments size to their content (the default)." },
        { "name": "justified", "class": "primitiv-segmented-control--justified", "description": "Segments share the track width equally — the classic equal-width segmented control." }
      ]
    }
  ],
  "subcomponents": [
    {
      "name": "item",
      "component": "Item",
      "element": "button",
      "class": "primitiv-segmented-control__item",
      "wrapTextChildren": true,
      "dataAttributes": [
        { "name": "data-state", "value": "checked", "when": "selected", "source": "auto" },
        { "name": "data-state", "value": "unchecked", "when": "not selected", "source": "auto" },
        { "name": "data-disabled", "value": "", "when": "disabled", "source": "auto" }
      ]
    }
  ],
  "customProperties": [
    { "name": "--primitiv-segmented-control-track-bg", "defaultsTo": "var(--primitiv-color-transparent)" },
    { "name": "--primitiv-segmented-control-track-border-color", "defaultsTo": "var(--primitiv-border-subtle)" },
    { "name": "--primitiv-segmented-control-track-border-width", "defaultsTo": "var(--primitiv-framed-control-border-width)" },
    { "name": "--primitiv-segmented-control-track-padding", "defaultsTo": "var(--primitiv-space-space-4)" },
    { "name": "--primitiv-segmented-control-track-gap", "defaultsTo": "var(--primitiv-space-space-4)" },
    { "name": "--primitiv-segmented-control-item-radius", "defaultsTo": "var(--primitiv-framed-control-md-radius)" },
    { "name": "--primitiv-segmented-control-radius", "defaultsTo": "calc(var(--primitiv-segmented-control-item-radius) + var(--primitiv-segmented-control-track-padding))" },
    { "name": "--primitiv-segmented-control-item-height", "defaultsTo": "var(--primitiv-framed-control-md-height)" },
    { "name": "--primitiv-segmented-control-item-padding-inline", "defaultsTo": "var(--primitiv-framed-control-md-padding-inline)" },
    { "name": "--primitiv-segmented-control-item-gap", "defaultsTo": "var(--primitiv-framed-control-md-gap)" },
    { "name": "--primitiv-segmented-control-item-icon-size", "defaultsTo": "var(--primitiv-framed-control-md-icon-size)" },
    { "name": "--primitiv-segmented-control-item-border-width", "defaultsTo": "var(--primitiv-framed-control-border-width)" },
    { "name": "--primitiv-segmented-control-item-bg", "defaultsTo": "var(--primitiv-action-secondary-default)" },
    { "name": "--primitiv-segmented-control-item-fg", "defaultsTo": "var(--primitiv-action-secondary-foreground-default)" },
    { "name": "--primitiv-segmented-control-item-border-color", "defaultsTo": "var(--primitiv-action-secondary-border-default)" },
    { "name": "--primitiv-segmented-control-item-bg-selected", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-segmented-control-item-fg-selected", "defaultsTo": "var(--primitiv-action-primary-foreground-default)" },
    { "name": "--primitiv-segmented-control-item-border-color-selected", "defaultsTo": "var(--primitiv-action-primary-border-default)" },
    { "name": "--primitiv-segmented-control-item-font-family", "defaultsTo": "var(--primitiv-label-md-font-family)" },
    { "name": "--primitiv-segmented-control-item-font-size", "defaultsTo": "var(--primitiv-label-md-font-size)" },
    { "name": "--primitiv-segmented-control-item-font-weight", "defaultsTo": "var(--primitiv-label-md-font-weight)" },
    { "name": "--primitiv-segmented-control-item-line-height", "defaultsTo": "var(--primitiv-label-md-line-height)" }
  ]
}
