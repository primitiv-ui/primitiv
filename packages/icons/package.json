{
  "name": "@primitiv-ui/icons",
  "version": "0.1.4",
  "description": "Fill-based SVG icon library for the Primitiv ecosystem. Icons inherit currentColor, scale via a size prop, accept all native SVG attributes, and tree-shake cleanly.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/primitiv-ui/primitiv.git",
    "directory": "packages/icons"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "qa": "pnpm qa:units",
    "qa:units": "vitest run --coverage",
    "qa:units:watch": "vitest --coverage"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0 || ^19.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "svgo": "^3.3.2",
    "tsx": "^4.19.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
