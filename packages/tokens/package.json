{
  "name": "@primitiv-ui/tokens",
  "version": "0.1.27",
  "description": "The DTCG-conformant design-token layer for the Primitiv ecosystem, plus helpers that transform Figma variable exports into DTCG JSON.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/primitiv-ui/primitiv.git",
    "directory": "packages/tokens"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "qa": "pnpm qa:units",
    "qa:units": "vitest run --coverage",
    "qa:units:watch": "vitest --coverage",
    "sync:serve": "tsx src/serve.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
