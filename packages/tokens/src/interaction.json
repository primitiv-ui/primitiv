{
  "hover": {
    "opacity": {
      "$type": "number",
      "$value": "{opacity.90}"
    }
  },
  "active": {
    "opacity": {
      "$type": "number",
      "$value": "{opacity.80}"
    }
  },
  "disabled": {
    "opacity": {
      "$type": "number",
      "$value": "{opacity.40}"
    }
  },
  "focus": {
    "ring": {
      "width": {
        "$type": "number",
        "$value": "{border-width.2}"
      },
      "offset": {
        "$type": "number",
        "$value": "{border-width.2}"
      }
    }
  },
  "motion": {
    "duration": {
      "feedback": {
        "$type": "number",
        "$value": "{duration.75}"
      },
      "control": {
        "$type": "number",
        "$value": "{duration.150}"
      },
      "expand": {
        "$type": "number",
        "$value": "{duration.200}"
      },
      "overlay": {
        "$type": "number",
        "$value": "{duration.300}"
      }
    }
  }
}
