{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "accordion",
  "version": "0.1.0",
  "description": "A vertically stacked set of collapsible sections — hairline rows with a chevron that flips open→closed (WAI-ARIA Accordion pattern).",
  "docs": "https://primitiv-ui.dev/docs/components/accordion",
  "root": {
    "element": "div",
    "class": "primitiv-accordion",
    "component": "Root"
  },
  "dataAttributes": [
    { "name": "data-orientation", "value": "horizontal", "when": "horizontal", "source": "auto" },
    { "name": "data-orientation", "value": "vertical", "when": "vertical", "source": "auto" }
  ],
  "modifiers": [
    {
      "name": "size",
      "default": "md",
      "description": "Control size for the whole widget; `data-density` scales each size further.",
      "options": [
        { "name": "xs", "class": "primitiv-accordion--xs", "description": "Extra small." },
        { "name": "sm", "class": "primitiv-accordion--sm", "description": "Small." },
        { "name": "md", "class": "primitiv-accordion--md", "description": "Medium (the default)." },
        { "name": "lg", "class": "primitiv-accordion--lg", "description": "Large." },
        { "name": "xl", "class": "primitiv-accordion--xl", "description": "Extra large." }
      ]
    }
  ],
  "subcomponents": [
    {
      "name": "item",
      "component": "Item",
      "element": "div",
      "class": "primitiv-accordion__item",
      "dataAttributes": []
    },
    {
      "name": "header",
      "component": "Header",
      "element": "h3",
      "class": "primitiv-accordion__header",
      "dataAttributes": []
    },
    {
      "name": "trigger",
      "component": "Trigger",
      "element": "button",
      "class": "primitiv-accordion__trigger",
      "wrapTextChildren": true,
      "dataAttributes": [
        { "name": "data-state", "value": "open", "when": "open", "source": "auto" },
        { "name": "data-state", "value": "closed", "when": "closed", "source": "auto" },
        { "name": "data-disabled", "value": "true", "when": "disabled", "source": "auto" },
        { "name": "data-disabled", "value": "false", "when": "not disabled", "source": "auto" }
      ]
    },
    {
      "name": "content",
      "component": "Content",
      "element": "div",
      "class": "primitiv-accordion__content",
      "dataAttributes": [
        { "name": "data-state", "value": "open", "when": "open", "source": "auto" },
        { "name": "data-state", "value": "closed", "when": "closed", "source": "auto" }
      ]
    },
    {
      "name": "trigger-icon",
      "component": "TriggerIcon",
      "element": "span",
      "class": "primitiv-accordion__trigger-icon",
      "dataAttributes": [
        { "name": "data-state", "value": "open", "when": "open", "source": "auto" },
        { "name": "data-state", "value": "closed", "when": "closed", "source": "auto" }
      ]
    }
  ],
  "customProperties": [
    { "name": "--primitiv-accordion-item-border-color", "defaultsTo": "var(--primitiv-border-subtle)" },
    { "name": "--primitiv-accordion-item-border-width", "defaultsTo": "var(--primitiv-border-width-1)" },
    { "name": "--primitiv-accordion-trigger-padding-inline", "defaultsTo": "var(--primitiv-framed-control-md-padding-inline)" },
    { "name": "--primitiv-accordion-trigger-gap", "defaultsTo": "var(--primitiv-framed-control-md-gap)" },
    { "name": "--primitiv-accordion-trigger-icon-size", "defaultsTo": "var(--primitiv-framed-control-md-icon-size)" },
    { "name": "--primitiv-accordion-trigger-icon-rotation", "defaultsTo": "0deg" },
    { "name": "--primitiv-accordion-trigger-fg", "defaultsTo": "var(--primitiv-content-primary)" },
    { "name": "--primitiv-accordion-trigger-font-family", "defaultsTo": "var(--primitiv-label-md-font-family)" },
    { "name": "--primitiv-accordion-trigger-font-size", "defaultsTo": "var(--primitiv-label-md-font-size)" },
    { "name": "--primitiv-accordion-trigger-font-weight", "defaultsTo": "var(--primitiv-label-md-font-weight)" },
    { "name": "--primitiv-accordion-trigger-line-height", "defaultsTo": "var(--primitiv-label-md-line-height)" },
    { "name": "--primitiv-accordion-content-padding-block", "defaultsTo": "var(--primitiv-panel-padding-block)" },
    { "name": "--primitiv-accordion-content-padding-inline", "defaultsTo": "var(--primitiv-panel-padding-inline)" },
    { "name": "--primitiv-accordion-content-fg", "defaultsTo": "var(--primitiv-content-secondary)" },
    { "name": "--primitiv-accordion-content-font-family", "defaultsTo": "var(--primitiv-body-md-font-family)" },
    { "name": "--primitiv-accordion-content-font-size", "defaultsTo": "var(--primitiv-body-md-font-size)" },
    { "name": "--primitiv-accordion-content-font-weight", "defaultsTo": "var(--primitiv-body-md-font-weight)" },
    { "name": "--primitiv-accordion-content-line-height", "defaultsTo": "var(--primitiv-body-md-line-height)" },
    { "name": "--primitiv-accordion-content-transition-duration", "defaultsTo": "var(--primitiv-motion-duration-control)" },
    { "name": "--primitiv-accordion-content-transition-easing", "defaultsTo": "var(--primitiv-motion-easing-default)" }
  ]
}
