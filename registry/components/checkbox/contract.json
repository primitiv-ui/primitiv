{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "checkbox",
  "version": "0.1.0",
  "description": "A tri-state checkbox — an independent on/off (or mixed) form selection.",
  "docs": "https://primitiv-ui.dev/docs/components/checkbox",
  "root": {
    "element": "button",
    "class": "primitiv-checkbox"
  },
  "parts": [
    { "name": "indicator", "class": "primitiv-checkbox__indicator" }
  ],
  "modifiers": [
    {
      "name": "size",
      "default": "md",
      "description": "Control size; `data-density` scales each size further.",
      "options": [
        { "name": "xs", "class": "primitiv-checkbox--xs", "description": "Extra small." },
        { "name": "sm", "class": "primitiv-checkbox--sm", "description": "Small." },
        { "name": "md", "class": "primitiv-checkbox--md", "description": "Medium (the default)." },
        { "name": "lg", "class": "primitiv-checkbox--lg", "description": "Large." },
        { "name": "xl", "class": "primitiv-checkbox--xl", "description": "Extra large." }
      ]
    }
  ],
  "dataAttributes": [
    { "name": "data-state", "value": "checked", "when": "checked", "source": "auto" },
    { "name": "data-state", "value": "unchecked", "when": "unchecked", "source": "auto" },
    { "name": "data-state", "value": "indeterminate", "when": "indeterminate", "source": "auto" },
    { "name": "data-disabled", "value": "", "when": "disabled", "source": "auto" }
  ],
  "customProperties": [
    { "name": "--primitiv-checkbox-bg", "defaultsTo": "var(--primitiv-surface-default)" },
    { "name": "--primitiv-checkbox-bg-checked", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-checkbox-border-color", "defaultsTo": "var(--primitiv-border-strong)" },
    { "name": "--primitiv-checkbox-border-color-checked", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-checkbox-border-width", "defaultsTo": "var(--primitiv-border-width-1)" },
    { "name": "--primitiv-checkbox-mark-color", "defaultsTo": "var(--primitiv-action-primary-foreground-default)" },
    { "name": "--primitiv-checkbox-size", "defaultsTo": "var(--primitiv-checkbox-md-box-size)" },
    { "name": "--primitiv-checkbox-radius", "defaultsTo": "var(--primitiv-checkbox-md-box-radius)" },
    { "name": "--primitiv-checkbox-mark-size", "defaultsTo": "var(--primitiv-checkbox-md-mark-size)" }
  ]
}
