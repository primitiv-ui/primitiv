{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "radio",
  "version": "0.1.0",
  "description": "A single radio control — a one-way on selection you group yourself.",
  "docs": "https://primitiv-ui.dev/docs/components/radio",
  "root": {
    "element": "button",
    "class": "primitiv-radio"
  },
  "parts": [
    { "name": "indicator", "class": "primitiv-radio__indicator" }
  ],
  "modifiers": [
    {
      "name": "size",
      "default": "md",
      "description": "Control size; `data-density` scales each size further.",
      "options": [
        { "name": "xs", "class": "primitiv-radio--xs", "description": "Extra small." },
        { "name": "sm", "class": "primitiv-radio--sm", "description": "Small." },
        { "name": "md", "class": "primitiv-radio--md", "description": "Medium (the default)." },
        { "name": "lg", "class": "primitiv-radio--lg", "description": "Large." },
        { "name": "xl", "class": "primitiv-radio--xl", "description": "Extra large." }
      ]
    }
  ],
  "dataAttributes": [
    { "name": "data-state", "value": "checked", "when": "checked", "source": "auto" },
    { "name": "data-state", "value": "unchecked", "when": "unchecked", "source": "auto" },
    { "name": "data-disabled", "value": "", "when": "disabled", "source": "auto" }
  ],
  "customProperties": [
    { "name": "--primitiv-radio-bg", "defaultsTo": "var(--primitiv-surface-default)" },
    { "name": "--primitiv-radio-border-color", "defaultsTo": "var(--primitiv-border-strong)" },
    { "name": "--primitiv-radio-border-color-checked", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-radio-border-width", "defaultsTo": "var(--primitiv-border-width-1)" },
    { "name": "--primitiv-radio-dot-color", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-radio-size", "defaultsTo": "var(--primitiv-radio-md-box-size)" },
    { "name": "--primitiv-radio-radius", "defaultsTo": "var(--primitiv-radii-full)" },
    { "name": "--primitiv-radio-dot-size", "defaultsTo": "calc(var(--primitiv-radio-size) / 2)" }
  ]
}
