{
  "id": "tabs",
  "displayName": "Tabs",
  "kind": "registry",
  "status": "stable",
  "description": "An accessible tabbed interface â€” a tablist of triggers that switch between panels (WAI-ARIA Tabs pattern).",
  "headless": {
    "package": "@primitiv-ui/react",
    "importPath": "@primitiv-ui/react",
    "subComponents": [
      {
        "name": "Tabs.Root",
        "extends": "HTMLDivElement",
        "props": [
          {
            "name": "activationMode",
            "type": "\"automatic\" | \"manual\"",
            "required": false,
            "default": "\"automatic\"",
            "description": "When a focused trigger becomes active; see {@link TabsActivationMode}."
          },
          {
            "name": "defaultValue",
            "type": "string",
            "required": false,
            "default": null,
            "description": "Value of the tab active on first render."
          },
          {
            "name": "dir",
            "type": "\"ltr\" | \"rtl\"",
            "required": false,
            "default": null,
            "description": "Reading direction; see {@link TabsReadingDirection}. Inherited from the\nnearest `DirectionProvider` when omitted, falling back to `\"ltr\"`."
          },
          {
            "name": "lazyMount",
            "type": "boolean",
            "required": false,
            "default": null,
            "description": "When `true`, a panel's children are not rendered until that tab is first\nactivated. Once mounted they remain in the DOM across subsequent tab\nswitches (lazy mount, not unmount-on-hide). Useful for panels that own\nexpensive initialisation â€” e.g. a scroll-snap carousel whose initial\nscroll position must be set while the panel is visible."
          },
          {
            "name": "onChange",
            "type": "({ index, name }: TabMetadata) => void",
            "required": false,
            "default": null,
            "description": "Fired on every user-driven activation with the activated tab's metadata."
          },
          {
            "name": "onValueChange",
            "type": "(value: string) => void",
            "required": false,
            "default": null,
            "description": "Called with the requested value when the user activates a tab."
          },
          {
            "name": "orientation",
            "type": "\"horizontal\" | \"vertical\"",
            "required": false,
            "default": "\"horizontal\"",
            "description": "Layout axis; see {@link TabsOrientation}."
          },
          {
            "name": "value",
            "type": "string",
            "required": false,
            "default": null,
            "description": "Value of the currently active tab."
          }
        ],
        "contractProps": [
          {
            "name": "size",
            "type": "\"xs\" | \"sm\" | \"md\" | \"lg\" | \"xl\"",
            "default": "md",
            "description": "Control size for the whole widget; `data-density` scales each size further."
          }
        ],
        "dataAttributes": [
          "data-orientation"
        ]
      },
      {
        "name": "Tabs.List",
        "extends": "HTMLDivElement",
        "props": [
          {
            "name": "ariaLabelledBy",
            "type": "string",
            "required": false,
            "default": null,
            "description": "Id of an existing element to use as the tablist's accessible name,\nset as `aria-labelledby`. Mutually exclusive with `label`."
          },
          {
            "name": "label",
            "type": "string",
            "required": false,
            "default": null,
            "description": "Accessible name for the tablist, announced as `aria-label`. Pick a\nshort, human-readable description of the set (e.g. `\"Account\nsections\"`, not `\"Tabs\"`). Mutually exclusive with `ariaLabelledBy`."
          }
        ],
        "contractProps": [
          {
            "name": "justify",
            "type": "\"start\" | \"center\" | \"end\"",
            "default": "start",
            "description": "Alignment of the triggers along the tablist. Direction-aware â€” `start`/`end` follow the reading direction, flipping under RTL via the inherited `DirectionProvider`."
          }
        ],
        "dataAttributes": [
          "data-orientation"
        ]
      },
      {
        "name": "Tabs.Trigger",
        "extends": "HTMLButtonElement",
        "props": [
          {
            "name": "value",
            "type": "string",
            "required": true,
            "default": null,
            "description": "Identifies this trigger, linking it to the `Tabs.Content` of the same\nvalue. Not the visible label â€” use `children` for that."
          },
          {
            "name": "asChild",
            "type": "boolean",
            "required": false,
            "default": null,
            "description": "Render the child element instead of the default `<button>`. All tab\nARIA attributes and event handlers are merged onto the child. The child\nmust accept a `ref`. Useful for routing links that need tab semantics."
          },
          {
            "name": "disabled",
            "type": "boolean",
            "required": false,
            "default": "false",
            "description": "Removes the trigger from the roving tab order and marks it\n`aria-disabled`/`data-disabled`; arrow-key navigation skips it."
          },
          {
            "name": "ref",
            "type": "Ref<T>",
            "required": false,
            "default": null,
            "description": "Ref to the rendered element. Defaults to `HTMLButtonElement`; when using\n`asChild`, specify the child's element type (e.g. `HTMLAnchorElement`)."
          }
        ],
        "contractProps": [],
        "dataAttributes": [
          "data-state",
          "data-orientation",
          "data-disabled"
        ]
      },
      {
        "name": "Tabs.Content",
        "extends": "HTMLDivElement",
        "props": [
          {
            "name": "value",
            "type": "string",
            "required": true,
            "default": null,
            "description": "Value of the trigger this panel belongs to."
          }
        ],
        "contractProps": [],
        "dataAttributes": [
          "data-state",
          "data-orientation"
        ]
      }
    ]
  },
  "styled": {
    "installCommand": "primitiv add tabs",
    "rootClass": "primitiv-tabs",
    "customProperties": [
      {
